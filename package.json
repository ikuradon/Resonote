{
  "name": "resonote",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "vite dev",
    "dev:full": "wrangler pages dev --port 5173 --proxy 5174 -- vite dev --port 5174",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "build:ext": "vite build --config vite.config.extension.ts && mkdir -p dist-extension/sidepanel dist-extension/icons && cp src/extension/sidepanel/panel.html dist-extension/sidepanel/ && cp src/extension/icons/* dist-extension/icons/",
    "build:ext:chrome": "pnpm build:ext && cp src/extension/manifest.chrome.json dist-extension/manifest.json",
    "build:ext:firefox": "pnpm build:ext && cp src/extension/manifest.firefox.json dist-extension/manifest.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ikuradon/tsunagiya": "^0.4.0",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/chrome": "^0.1.37",
    "@types/node": "^25.5.0",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "nostr-typedef": "^0.13.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.53.12",
    "svelte-check": "^4.4.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "webextension-polyfill": "^0.12.0",
    "wrangler": "^4.73.0"
  },
  "dependencies": {
    "@ikuradon/emoji-kitchen-mart": "^7.0.0",
    "@ikuradon/emoji-kitchen-mart-data": "^2.0.0",
    "@konemono/nostr-login": "^1.15.1",
    "@rx-nostr/crypto": "^0.0.0",
    "@scure/base": "^2.0.0",
    "idb": "^8.0.3",
    "nostr-tools": "^2.23.3",
    "rx-nostr": "^3.6.2",
    "rxjs": "^7.8.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "undici@>=7.0.0 <7.24.0": ">=7.24.0",
      "cookie@<0.7.0": ">=0.7.0"
    }
  }
}
