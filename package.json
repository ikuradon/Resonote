{
  "name": "resonote",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "vite dev",
    "dev:full": "wrangler pages dev --port 5173 --proxy 5174 -- vite dev --port 5174",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "check:structure": "node scripts/check-structure.mjs",
    "graph:imports": "node scripts/print-import-graph.mjs",
    "graph:imports:summary": "node scripts/print-import-graph.mjs --summary",
    "perf:bundle": "pnpm build && node scripts/print-bundle-summary.mjs",
    "perf:bundle:summary": "pnpm build && node scripts/print-bundle-summary.mjs --summary",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "pretest:e2e": "pnpm build:e2e-helpers",
    "test:e2e": "playwright test",
    "preview:e2e": "wrangler pages dev .svelte-kit/cloudflare --port 4173 --ip 127.0.0.1",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "build:e2e-helpers": "esbuild node_modules/@ikuradon/tsunagiya/esm/mod.js --bundle --format=iife --global-name=Tsunagiya --outfile=e2e/helpers/tsunagiya-bundle.js --platform=browser",
    "build:ext": "vite build --config vite.config.extension.ts && mkdir -p dist-extension/sidepanel dist-extension/icons && cp src/extension/sidepanel/panel.html dist-extension/sidepanel/ && cp src/extension/icons/* dist-extension/icons/",
    "build:ext:chrome": "pnpm build:ext && cp src/extension/manifest.chrome.json dist-extension/manifest.json",
    "build:ext:firefox": "pnpm build:ext && cp src/extension/manifest.firefox.json dist-extension/manifest.json"
  },
  "devDependencies": {
    "@codecov/vite-plugin": "^1.9.1",
    "@eslint/js": "^10.0.1",
    "@ikuradon/tsunagiya": "^0.4.0",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/chrome": "^0.1.38",
    "@types/node": "^25.5.0",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-svelte": "^3.16.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "nostr-typedef": "^0.13.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.0",
    "svelte-check": "^4.4.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "webextension-polyfill": "^0.12.0",
    "wrangler": "^4.78.0"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@ikuradon/auftakt": "^0.1.0",
    "@ikuradon/emoji-kitchen-mart": "^7.0.0",
    "@ikuradon/emoji-kitchen-mart-data": "^2.0.0",
    "@konemono/nostr-login": "^1.15.2",
    "@rx-nostr/crypto": "^0.0.0",
    "@scure/base": "^2.0.0",
    "hono": "^4.12.9",
    "idb": "^8.0.3",
    "nostr-tools": "^2.23.3",
    "rx-nostr": "^3.6.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "undici@<6.24.0": ">=6.24.0",
      "cookie@<0.7.0": ">=0.7.0"
    }
  }
}
