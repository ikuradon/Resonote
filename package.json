{
  "name": "resonote",
  "private": true,
  "version": "0.2.3",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "vite dev",
    "dev:full": "wrangler pages dev --port 5173 --proxy 5174 -- vite dev --port 5174",
    "build": "vite build",
    "build:e2e": "vite build --mode e2e",
    "preview": "vite preview",
    "prepare": "(svelte-kit sync || echo '') && simple-git-hooks",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "check:structure": "node scripts/check-structure.mjs && pnpm run check:no-test-code-in-src",
    "check:no-test-code-in-src": "node scripts/check-no-test-code-in-src.mjs",
    "check:auftakt-migration": "node scripts/check-auftakt-migration.mjs",
    "check:auftakt:nips": "node --experimental-strip-types scripts/check-auftakt-nips.ts",
    "check:auftakt:strict-closure": "git ls-files -co --exclude-standard | node --experimental-strip-types scripts/check-auftakt-strict-closure.ts",
    "check:auftakt:strict-goal-audit": "node --experimental-strip-types scripts/check-auftakt-strict-goal-audit.ts",
    "test:auftakt:core": "vitest run packages/core/src/",
    "test:auftakt:runtime": "vitest run packages/runtime/src/",
    "test:auftakt:storage": "vitest run packages/adapter-dexie/src/",
    "test:auftakt:resonote": "vitest run packages/resonote/src/",
    "test:auftakt:app-regression": "vitest run src/shared/auftakt/cached-read.test.ts src/shared/browser/profile.svelte.test.ts src/shared/browser/relays.test.ts src/features/comments/ui/comment-view-model.test.ts src/features/notifications/ui/notification-feed-view-model.test.ts src/features/relays/ui/relay-settings-view-model.test.ts src/features/comments/application/comment-actions.test.ts src/features/content-resolution/application/resolve-content.test.ts",
    "test:auftakt:e2e": "playwright test e2e/reply-thread.test.ts e2e/comment-flow.test.ts e2e/reaction-delete-reply.test.ts e2e/notifications-page.test.ts e2e/profile-data.test.ts e2e/relay-settings-data.test.ts e2e/nip19-routes.test.ts e2e/content-page.test.ts",
    "check:auftakt-semantic": "node scripts/check-auftakt-migration.mjs --semantic-guard && pnpm run test:auftakt:core && pnpm run test:auftakt:storage && pnpm run test:auftakt:resonote && pnpm run test:auftakt:app-regression && pnpm run test:auftakt:e2e",
    "check:auftakt-complete": "pnpm run check:auftakt-migration -- --proof && pnpm run check:auftakt-migration -- --report consumers && pnpm run test:packages && pnpm run check:auftakt-semantic && pnpm run check:auftakt:strict-closure && pnpm run check:auftakt:strict-goal-audit && pnpm run check && pnpm run build",
    "graph:imports": "node scripts/print-import-graph.mjs",
    "graph:imports:summary": "node scripts/print-import-graph.mjs --summary",
    "perf:bundle": "pnpm build && node scripts/print-bundle-summary.mjs",
    "perf:bundle:summary": "pnpm build && node scripts/print-bundle-summary.mjs --summary",
    "test": "vitest run",
    "test:packages": "vitest run packages/",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "pretest:e2e": "pnpm build:e2e-helpers",
    "test:e2e": "playwright test",
    "preview:e2e": "wrangler pages dev .svelte-kit/cloudflare --port 4173 --ip 127.0.0.1",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "build:e2e-helpers": "esbuild node_modules/@ikuradon/tsunagiya/esm/mod.js --bundle --format=iife --global-name=Tsunagiya --outfile=e2e/helpers/tsunagiya-bundle.js --platform=browser",
    "build:ext": "vite build --config vite.config.extension.ts && mkdir -p dist-extension/sidepanel dist-extension/icons && cp src/extension/sidepanel/panel.html dist-extension/sidepanel/ && cp src/extension/icons/* dist-extension/icons/",
    "build:ext:chrome": "pnpm build:ext && cp src/extension/manifest.chrome.json dist-extension/manifest.json",
    "build:ext:firefox": "pnpm build:ext && cp src/extension/manifest.firefox.json dist-extension/manifest.json"
  },
  "devDependencies": {
    "@codecov/vite-plugin": "^2.0.1",
    "@eslint/js": "^10.0.1",
    "@ikuradon/tsunagiya": "^0.4.0",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/chrome": "^0.1.40",
    "@types/node": "^25.6.0",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-svelte": "^3.16.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "nano-staged": "^1.0.2",
    "nostr-typedef": "^0.13.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "simple-git-hooks": "^2.13.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.2",
    "webextension-polyfill": "^0.12.0",
    "wrangler": "^4.78.0"
  },
  "dependencies": {
    "@auftakt/adapter-dexie": "workspace:*",
    "@auftakt/core": "workspace:*",
    "@auftakt/resonote": "workspace:*",
    "@auftakt/runtime": "workspace:*",
    "@hono/zod-validator": "^0.7.6",
    "@ikuradon/emoji-kitchen-mart": "^7.0.0",
    "@ikuradon/emoji-kitchen-mart-data": "^2.0.0",
    "@konemono/nostr-login": "^1.15.2",
    "@scure/base": "^2.0.0",
    "hono": "^4.12.14",
    "idb": "^8.0.3",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "undici@<6.24.0": ">=6.24.0",
      "cookie@<0.7.0": ">=0.7.0"
    }
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "**/*.{ts,js,svelte}": [
      "prettier --write",
      "eslint --fix"
    ],
    "**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
